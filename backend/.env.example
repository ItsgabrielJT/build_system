# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://TU_USUARIO@localhost:5432/edificios

# ── Autenticación ─────────────────────────────────────────────────────────────
# DEV_MODE=true omite la verificación del token JWT (SOLO para desarrollo).
# En producción, cambiar a false y configurar FIREBASE_PROJECT_ID.
DEV_MODE=true
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── CORS (orígenes separados por coma) ────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── Reglas de negocio ─────────────────────────────────────────────────────────
# Día del mes a partir del cual un período vencido se considera en mora.
DUE_DAY=5

# ── Mailjet (Notificaciones de Correo) ───────────────────────────────────────
MAILJET_API_KEY=your_mailjet_api_key_here
MAILJET_API_SECRET=your_mailjet_api_secret_here
MAILJET_FROM_EMAIL=no-reply@edificios.com
MAILJET_FROM_NAME="Build System"
ADMIN_NOTIFICATION_EMAIL=admin@edificios.com

